# ============================================================
# Vibha Events — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Comma-separated list of allowed CORS origins (production only)
ALLOWED_ORIGINS="https://yourdomain.com"

# ── Authentication ────────────────────────────────────────────
# Generate a bcrypt hash of your admin password:
#   npm run hash -- yourpassword
ADMIN_PASSWORD_HASH="$2b$12$..."

# Random secret for signing JWTs (32+ characters recommended)
JWT_SECRET="replace-with-a-long-random-secret"

# ── AI Integration (server-side only) ────────────────────────
GEMINI_API_KEY="your-google-gemini-api-key"

# ── Firebase (frontend, VITE_* prefix required) ──────────────
# These are safe to expose in the browser — security comes from Firestore rules.
VITE_FIREBASE_API_KEY="your-firebase-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"
VITE_FIREBASE_DATABASE_ID="your-firestore-database-id"
